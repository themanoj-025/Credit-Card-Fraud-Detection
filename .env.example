# ════════════════════════════════════════════════════════════════
# FraudLens — Environment Configuration
# Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════════

# ─── API Authentication ────────────────────────────────────────
# API keys for the FraudLens API. Format: <sha256_hash>=<role>
# Multiple keys can be separated by semicolons.
# Generate a key: python -c "import hashlib; print(hashlib.sha256(b'my-api-key').hexdigest() + '=admin')"
# If not set, authentication is disabled (dev mode).
FRAUDLENS_API_KEYS=

# Admin secret for key management endpoint (if implemented)
FRAUDLENS_ADMIN_SECRET=

# ─── LLM Services ──────────────────────────────────────────────
# Anthropic API key for case narrator and analyst copilot.
# Required for: LLM-powered explanations, copilot chat.
ANTHROPIC_API_KEY=

# ─── Rate Limiting Backend ─────────────────────────────────────
# Default: redis (safe for multi-worker deployments).
# Set to "memory" for local dev without Docker/Redis.
RATE_LIMIT_BACKEND=redis

# ─── Redis (for production rate limiting + caching) ────────────
# If not set and RATE_LIMIT_BACKEND=redis, falls back to in-memory with warning.
REDIS_URL=redis://localhost:6379/0

# ─── Kaggle Data Download (optional) ──────────────────────────
# If set, `make setup-data` downloads the real creditcard.csv from Kaggle.
# If not set, a synthetic dataset is generated automatically.
KAGGLE_USERNAME=
KAGGLE_KEY=

# ─── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (for production).
# Format: postgresql+asyncpg://user:password@host:5432/fraudlens
DATABASE_URL=

# ─── MLflow ────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── Model Paths (override defaults) ──────────────────────────
# FRAUDLENS_MODELS_DIR=/path/to/models
