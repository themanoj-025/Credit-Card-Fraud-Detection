# ════════════════════════════════════════════════════════════════
# FraudLens — .gitignore
# ════════════════════════════════════════════════════════════════

# ─── Python ───────────────────────────────────────────────────
*.py[cod]
__pycache__/
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# ─── Environment ──────────────────────────────────────────────
.env
venv/
.venv/
env/

# ─── Data ──────────────────────────────────────────────────────
data/raw/
data/processed/
Dataset/

# ─── Models ──────────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/rag_index/
!models/.gitkeep

# ─── MLflow ──────────────────────────────────────────────────
mlruns/
mlflow.db

# ─── Reports ─────────────────────────────────────────────────
reports/figures/
reports/*.csv
reports/*.json

# ─── Monitoring ──────────────────────────────────────────────
monitoring/*.json

# ─── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Testing ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.coverage.*
*.log

# ─── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Archived / Dead Code ────────────────────────────────────
src/**/_archived_*
monitoring/_archived_*

# ─── Generated Training Artifacts ───────────────────────────
models/threshold.txt
models/*.json
catboost_info/

# ─── ML Model Formats (defensive) ───────────────────────────
*.pth
*.h5
*.onnx

# ─── Type Checking ──────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
